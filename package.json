{
  "name": "Phayura",
  "version": "1.1.0",
  "description": "ToS-compliant window manager for Flyff Universe dual-clienting",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "koffi": "^2.10.0"
  },
  "build": {
    "appId": "com.Phayura.app",
    "productName": "Phayura",
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
